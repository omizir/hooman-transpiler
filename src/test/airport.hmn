template <Flight>
shape
    <text> as <flightnumber>
    <number> as <duration>
    <text> as <takeoff>
    <text> as <destination>

    assemble with <text as fnr, number as dur, text as tkf, text as dst>
    do
        store <fnr> in self<flightnumber>
        store <dur> in self<duration>
        store <tkf> in self<takeoff>
        store <dst> in self<destination>
    end

    callable as <print>
    do
        print <
            Flight: <self<flightnumber>> \n
            From: <self<takeoff>> To: <self<destination>> \n
            Duration: <self<duration>>
        >
        is <self<duration> greater than <4>>
        do
            print <Long-haul flight. \n>
        end
        otherwise
        do
            print <Short-haul flight. \n>
        end
    end

    callable as <setFlightnumber> with <text as fnr>
    do
        store <fnr> in self<flightnumber>
    end

    callable as <setDuration> with <number as dur>
    do
        store <dur> in self<duration>
    end

    callable as <setTakeoff> with <text as tkf>
    do
        store <tkf> in self<takeoff>
    end

    callable as <setDestination> with <text as dst>
    do
        store <dst> in self<destination>
    end
end

template <Airport>
shape
    <text> as <name>
    <list of Flight> as <flights>

    assemble with <text as name, list of Flight as flights>
    do
        store <name> in self<name>
        store <flights> in self<flights>
    end

    callable as <printFlights>
    do
        loop <self<flights>> as <flight>
        do
            call <flight<print>>
        end
    end

    callable as <print>
    do
        print <
            Airport <self<name>> \n
            Flights: \n
            ------------------------ \n
        >
        call <self<printFlights>>
    end
end

create <Flight> as <cgnToVie> with <<F01>, <2>, <CGN>, <VIE>>
create <Flight> as <vieToDbx> with <<F02>, <6>, <VIE>, <DBX>>

create <Airport> as <viennaAirport> with <<Vienna International Airport>, <<vieToDbx>, <cgnToVie>>>
call <viennaAirport<print>>
