{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "<", "close": ">" }
  ],
  "surroundingPairs": [
    ["<", ">"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^(shape|do|is)\\s*$",
    "decreaseIndentPattern": "^\\s*end\\s*$"
  }
}
